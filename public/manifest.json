{
    "manifest_version": 3,
    "name": "COS - Context Operating System",
    "version": "1.0",
    "description": "Premium sliding Context Operating System overlay injected into any tab.",
    "permissions": [
        "tabs",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "16": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Toggle COS Overlay",
        "default_icon": {
            "16": "logo.png",
            "48": "logo.png",
            "128": "logo.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "logo.png",
                "content.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}